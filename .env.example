# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/axiospaypay?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-strong-random-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-different-strong-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Interswitch ──────────────────────────────────────────────────────────────
INTERSWITCH_CLIENT_ID="your-interswitch-client-id"
INTERSWITCH_CLIENT_SECRET="your-interswitch-client-secret"
INTERSWITCH_BASE_URL="https://sandbox.interswitchng.com"
INTERSWITCH_MERCHANT_CODE="your-merchant-code"
INTERSWITCH_PAY_ITEM_ID="your-pay-item-id"
INTERSWITCH_WEBHOOK_SECRET="your-webhook-secret"

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_SID="your-twilio-account-sid"
TWILIO_TOKEN="your-twilio-auth-token"
TWILIO_FROM="+1234567890"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
